{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "ihub_users_count", "legendFormat": "Users" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "title": "Total Entries",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [{ "expr": "sum(ihub_entries_count)", "legendFormat": "Entries" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "title": "Total Comments",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [{ "expr": "ihub_comments_count", "legendFormat": "Comments" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "title": "HTTP Requests / min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(rate(ihub_http_requests_total[1m])) * 60", "legendFormat": "req/min" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "orange", "value": null }] } } }
    },
    {
      "title": "Registrations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [{ "expr": "sum(ihub_register_total)", "legendFormat": "Registrations" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "yellow", "value": null }] } } }
    },
    {
      "title": "Backups",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [{ "expr": "sum(ihub_backup_total)", "legendFormat": "Backups" }],
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }] } } }
    },
    {
      "title": "Entries by Type",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [{ "expr": "ihub_entries_count", "legendFormat": "{{type}}" }]
    },
    {
      "title": "Pushes over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "targets": [
        { "expr": "sum by (type) (rate(ihub_push_total[5m]))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "title": "Pushes by User",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum by (user) (rate(ihub_push_total[5m]))", "legendFormat": "{{user}}" }
      ]
    },
    {
      "title": "Views by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "sum by (type) (rate(ihub_view_total[5m]))", "legendFormat": "{{type}}" }
      ]
    },
    {
      "title": "Comments by User",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "sum by (user) (ihub_comment_total)", "legendFormat": "{{user}}" }
      ]
    },
    {
      "title": "Searches over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "rate(ihub_search_total[5m])", "legendFormat": "searches/s" }
      ]
    },
    {
      "title": "Removes by User",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "expr": "sum by (user) (rate(ihub_remove_total[5m]))", "legendFormat": "{{user}}" }
      ]
    },
    {
      "title": "HTTP Requests by Method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "expr": "sum by (method) (rate(ihub_http_requests_total[5m]))", "legendFormat": "{{method}}" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["ihub"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "ihub Registry",
  "uid": "ihub-registry"
}
